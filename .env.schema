# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
# AI-safe: agents may read this schema; secret values stay in .env.local or Proton Pass.
#
# @plugin(@varlock/proton-pass-plugin)
# @initProtonPass()
# @defaultRequired=false @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# ----------

# Kubernetes context used for cluster operations in this repo.
# @type=string(minLength=1)
# @example="homelab"
KUBE_CONTEXT=homelab

# Repo-specific Talos config path for talosctl. Relative to repo root/current working directory.
# @sensitive
# @example="./kubernetes/talos/clusterconfig/talosconfig"
TALOSCONFIG=./kubernetes/talos/clusterconfig/talosconfig

# Proton Pass CLI login username. Optional if pass-cli is already logged in.
# @docs("Proton Pass plugin", https://varlock.dev/plugins/proton-pass/)
# @example="user@example.com"
PROTON_PASS_USERNAME=

# Proton Pass account password for non-interactive login.
# @type=protonPassPassword @sensitive
PROTON_PASS_PASSWORD=

# Proton Pass TOTP for non-interactive login.
# @type=protonPassTotp @sensitive
PROTON_PASS_TOTP=

# Proton Pass extra password, if enabled.
# @type=protonPassExtraPassword @sensitive
PROTON_PASS_EXTRA_PASSWORD=

# UniFi controller/base URL for read-only network inspection.
# Resolved from Proton Pass: pass://Personal/UniFi/Host
# @type=url
# @docs("UniFi Network API", https://developer.ui.com/)
# @docs("Proton Pass plugin", https://varlock.dev/plugins/proton-pass/)
# @example="https://unifi.example.com"
UNIFI_HOST=protonPass(pass://Personal/UniFi/Host, allowMissing=true)

# Temporary read-only UniFi API token. Prefer short-lived/site-scoped token.
# Resolved from Proton Pass: pass://Personal/UniFi/Token
# @sensitive
# @docs("Proton Pass plugin", https://varlock.dev/plugins/proton-pass/)
UNIFI_TOKEN=protonPass(pass://Personal/UniFi/Token, allowMissing=true)

# IoT WiFi SSID to attach to VLAN 20.
IOT_WIFI_SSID="The Creep Nextdoor IoT"

# IoT WiFi WPA2 password stored in Proton Pass WiFi item.
# Resolved from Proton Pass: pass://Personal/The Creep Nextdoor IoT/password
# @sensitive
# @docs("Proton Pass plugin", https://varlock.dev/plugins/proton-pass/)
IOT_WIFI_PASSWORD=protonPass("pass://Personal/The Creep Nextdoor IoT/password", allowMissing=true)

# Technitium DNS admin URL from Proton Pass.
# Proton Pass item title is currently "Technitum".
# @type=url
TECHNITIUM_HOST=protonPass("pass://Personal/Technitum/urls", allowMissing=true)

# Technitium DNS admin username from Proton Pass.
TECHNITIUM_USERNAME=protonPass("pass://Personal/Technitum/username", allowMissing=true)

# Technitium DNS admin password from Proton Pass.
# @sensitive
# @docs("Proton Pass plugin", https://varlock.dev/plugins/proton-pass/)
TECHNITIUM_PASSWORD=protonPass("pass://Personal/Technitum/password", allowMissing=true)

# Home Assistant URL.
# @type=url
HOME_ASSISTANT_HOST=protonPass("pass://Personal/Home Assistant/host", allowMissing=true)

# Home Assistant long-lived access token from Proton Pass.
# @sensitive
# @docs("Home Assistant REST API", https://developers.home-assistant.io/docs/api/rest/)
# @docs("Proton Pass plugin", https://varlock.dev/plugins/proton-pass/)
HOME_ASSISTANT_TOKEN=protonPass("pass://Personal/Home Assistant/token", allowMissing=true)
