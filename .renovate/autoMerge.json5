{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  // Auto-merge everything via GitHub native auto-merge; a ruleset on main
  // requires 1 approval, so nothing merges until reviewed.
  automerge: true,
  automergeType: "pr",
  automergeStrategy: "rebase",
  // GitHub-native auto-merge ignores automergeStrategy and picks the repo's
  // detected method (squash first). Renovate merging directly honors rebase.
  platformAutomerge: false,
  packageRules: [
    {
      description: "GitHub Actions: wait out fresh releases",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
    },
  ],
}
